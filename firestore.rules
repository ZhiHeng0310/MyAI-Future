rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for common auth checks
    function isSignedIn() {
      return request.auth != null;
    }

    function isPatient(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isDoctor(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isDoctorRole() {
      return request.auth != null && request.auth.token.role == 'doctor';
    }

    function isDoctorUser() {
      return request.auth != null && exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    function isStaff() {
      return request.auth != null && (request.auth.token.role == 'staff' || request.auth.token.role == 'doctor');
    }

    // ── PATIENTS: owner and doctors can read; owner can write ────────────────
    match /patients/{userId} {
      allow read: if isPatient(userId) || isDoctorRole() || isDoctorUser();
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update: if isPatient(userId);
      allow delete: if isPatient(userId);
    }

    // ── NESTED PATIENT MEDICATIONS: read from AI and doctor contexts ─────────
    match /patients/{patientId}/medications/{medId} {
      allow read: if isSignedIn() && (
        isPatient(patientId) || isDoctorRole() || isDoctorUser()
      );
      allow create: if isDoctorRole() || isDoctorUser();
      allow update: if isDoctorRole() || isDoctorUser();
      allow delete: if isDoctorRole() || isDoctorUser();
    }

    // ── DOCTORS: read by authenticated users; doctor can modify own record ────
    match /doctors/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update: if isDoctor(docId);
      allow delete: if isDoctor(docId);
    }

    // ── MEDICATIONS: patient reads own; doctor reads/writes prescribed ────────
    match /medications/{medId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow create: if isDoctorRole() || isDoctorUser();
      allow update: if isDoctorRole() || isDoctorUser() || (
        isPatient(resource.data.patientId) &&
        request.resource.data.diff(resource.data).affectedKeys().size() == 1 &&
        'takenSlots' in request.resource.data.diff(resource.data).affectedKeys()
      );
      allow delete: if isDoctorRole() || isDoctorUser();
    }

    // ── DOSE LOGS: patient creates; patient/doctor read ─────────────────────
    match /dose_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // ── CHECK-INS: patient creates; both can read ──────────────────────────────
    match /checkins/{checkInId} {
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctorRole()
      );
      allow update, delete: if false;
    }

    // ── HEALTH ALERTS: patient creates (triggers AI); doctor reads/updates ────
    match /health_alerts/{alertId} {
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow update: if isSignedIn() && (
        isDoctorRole() || isDoctorUser() || request.auth.token.role == 'staff'
      );
      allow delete: if isDoctorRole() || isDoctorUser();
    }

    // ── URGENT MESSAGES: AI can write urgent patient-doctor alerts ──────────
    match /urgent_messages/{messageId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isStaff()
      );
      allow update, delete: if isStaff();
    }

    // ── DOCTOR INBOX: doctor reads/updates own; system can create ────────────
    match /doctor_inbox/{doctorId}/messages/{messageId} {
      allow read: if isDoctor(doctorId);
      allow create: if isSignedIn() && request.resource.data.doctorId == doctorId;
      allow update: if isDoctor(doctorId);
      allow list: if isDoctor(doctorId);
      allow delete: if isDoctor(doctorId);
    }

    // ── PATIENT INBOX: patient reads own; system can create ──────────────────
    match /patient_inbox/{patientId}/messages/{messageId} {
      allow read: if isPatient(patientId);
      allow create: if isSignedIn() && request.resource.data.patientId == patientId;
      allow update: if isPatient(patientId);
      allow list: if isPatient(patientId);
      allow delete: if isPatient(patientId);
    }

    // ── APPOINTMENTS: patients can book and cancel their own slots ──────────
    match /appointments/{doctorId}/slots/{slotId} {
      allow read: if isSignedIn();  // allow all authenticated users to read for availability
      allow create: if isSignedIn() &&
        request.resource.data.doctorId == doctorId &&
        request.resource.data.patientId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctor(doctorId)
      );
      allow delete: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctor(doctorId)
      );
    }

    // ── COLLECTION GROUP: allow patients to query their appointments across all doctors ──
    match /{path=**}/slots/{slotId} {
      allow read: if isSignedIn() && resource.data.patientId == request.auth.uid;
    }

    // ── QUEUES: patients join; staff manages ───────────────────────────────────
    match /queues/{clinicId}/entries/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.patientId ||
        isStaff() ||
        isDoctorUser()
      );
      allow list: if isSignedIn();
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.patientId ||
        isStaff() ||
        isDoctorUser()
      );
    }

    // ── PUSH NOTIFICATIONS: system writes (for Cloud Functions) ───────────────
    match /push_notifications/{notifId} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── NOTIFICATIONS: top-level app inbox entries ───────────────────────────
    match /notifications/{notificationId} {
      allow create: if isSignedIn() && request.resource.data.userId is string;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff()
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff()
      );
    }

    // ── LEGACY ALERTS: keep for backward compatibility ──────────────────────
    match /alerts/{alertId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // ── DENY ALL OTHER ACCESS ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
