rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Patients: only the owner can read/write their own record
    match /patients/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Queue: authenticated users can read; only they can write their own entry
    match /queues/{clinicId}/entries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.patientId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.patientId == request.auth.uid
            || request.auth.token.role == 'staff');
    }

    // Medications: only the patient can read; staff can write
    match /medications/{medId} {
      allow read: if request.auth != null
        && resource.data.patientId == request.auth.uid;
      allow write: if request.auth != null
        && request.auth.token.role == 'staff';
    }

    // Dose logs: patient creates their own logs
    match /dose_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Check-ins: patient writes, staff reads
    match /checkins/{checkInId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null
        && (resource.data.patientId == request.auth.uid
            || request.auth.token.role == 'staff');
    }

    // Alerts: authenticated users create; staff resolves
    match /alerts/{alertId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && request.auth.token.role == 'staff';
    }
  }
}
