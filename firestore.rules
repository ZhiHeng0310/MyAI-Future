rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ══════════════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isPatient(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isDoctor(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isDoctorRole() {
      return request.auth != null && request.auth.token.role == 'doctor';
    }

    function isDoctorUser() {
      return request.auth != null && exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    function isStaff() {
      return request.auth != null && (request.auth.token.role == 'staff' || request.auth.token.role == 'doctor');
    }

    function isUserRole(role) {
      return request.auth != null && request.auth.token.role == role;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // USERS COLLECTION (Combined patients and doctors)
    // ══════════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Read: Own profile OR doctors can read all users
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isDoctorRole() ||
        isDoctorUser() ||
        isStaff()
      );

      // Create: Own profile only
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Update: Own profile OR doctors can update patient assignments
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        (isDoctorRole() || isDoctorUser()) && resource.data.role == 'patient'
      );

      // Delete: Own profile only
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PATIENTS COLLECTION (Legacy - for backward compatibility)
    // ══════════════════════════════════════════════════════════════════════════
    match /patients/{userId} {
      allow read: if isPatient(userId) || isDoctorRole() || isDoctorUser();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isPatient(userId) || (
        (isDoctorRole() || isDoctorUser()) &&
        request.resource.data.assignedDoctorId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedDoctorId'])
      ) || (isPatient(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']));
      allow delete: if isPatient(userId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // NESTED PATIENT MEDICATIONS
    // ══════════════════════════════════════════════════════════════════════════
    match /patients/{patientId}/medications/{medId} {
      allow read: if isSignedIn() && (
        isPatient(patientId) || isDoctorRole() || isDoctorUser()
      );
      allow create: if isSignedIn() && (
        request.resource.data.doctorId == request.auth.uid &&
        request.resource.data.patientId == patientId &&
        request.resource.data.patientId != request.auth.uid &&
        request.resource.data.name is string &&
        request.resource.data.dosage is string &&
        request.resource.data.frequency is string
      );
      allow update: if isDoctorRole() || isDoctorUser();
      allow delete: if isDoctorRole() || isDoctorUser();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DOCTORS COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /doctors/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == docId;
      allow update: if isDoctor(docId) || (isDoctor(docId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']));
      allow delete: if isDoctor(docId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // MEDICATIONS COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /medications/{medId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow create: if isSignedIn() && (
        request.resource.data.doctorId == request.auth.uid &&
        request.resource.data.patientId is string &&
        request.resource.data.name is string &&
        request.resource.data.dosage is string &&
        request.resource.data.frequency is string &&
        request.resource.data.reminderTimes is list &&
        request.resource.data.active is bool
      );
      allow update: if isDoctorRole() || isDoctorUser() || (
        isPatient(resource.data.patientId) &&
        request.resource.data.diff(resource.data).affectedKeys().size() <= 2 &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['takenSlots', 'lastTaken'])
      );
      allow delete: if isDoctorRole() || isDoctorUser();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AI MEDICAL REPORTS COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /medical_reports/{reportId} {
      // Doctors can create and read all reports
      // Patients can read their own reports
      allow create: if isSignedIn() && (isDoctorRole() || isDoctorUser());

      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );

      allow update: if isSignedIn() && (
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );

      allow delete: if isSignedIn() && (
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // AI REPORT SUMMARIES COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /report_summaries/{summaryId} {
      // Doctors can create summaries
      // Patients can read their own summaries
      allow create: if isSignedIn() && (isDoctorRole() || isDoctorUser());

      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );

      allow update: if isSignedIn() && (isDoctorRole() || isDoctorUser());

      allow delete: if isSignedIn() && (isDoctorRole() || isDoctorUser());
    }

    // ══════════════════════════════════════════════════════════════════════════
    // INBOX MESSAGES COLLECTION (AI-generated summaries sent to patients)
    // ══════════════════════════════════════════════════════════════════════════
    match /inbox_messages/{messageId} {
      // Doctors can create messages
      // Patients can read their own messages
      allow create: if isSignedIn() && (isDoctorRole() || isDoctorUser());

      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );

      allow update: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );

      allow delete: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DOSE LOGS COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /dose_logs/{logId} {
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // MEDICATION LOGS COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /medication_logs/{logId} {
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CHECK-INS COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /checkins/{checkInId} {
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // HEALTH ALERTS COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /health_alerts/{alertId} {
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow update: if isSignedIn() && (
        isDoctorRole() || isDoctorUser() || isStaff()
      );
      allow delete: if isDoctorRole() || isDoctorUser();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // URGENT MESSAGES COLLECTION
    // ══════════════════════════════════════════════════════════════════════════
    match /urgent_messages/{messageId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isStaff() ||
        isDoctorUser()
      );
      allow update, delete: if isStaff() || isDoctorUser();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DOCTOR INBOX (nested messages)
    // ══════════════════════════════════════════════════════════════════════════
    match /doctor_inbox/{doctorId}/messages/{messageId} {
      allow read: if isDoctor(doctorId) || isDoctorUser();
      allow create: if isSignedIn() && request.resource.data.doctorId == doctorId;
      allow update: if isDoctor(doctorId) || isDoctorUser();
      allow list: if isDoctor(doctorId) || isDoctorUser();
      allow delete: if isDoctor(doctorId) || isDoctorUser();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PATIENT INBOX (nested messages)
    // ══════════════════════════════════════════════════════════════════════════
    match /patient_inbox/{patientId}/messages/{messageId} {
      allow read: if isPatient(patientId);
      allow create: if isSignedIn() && (
        request.resource.data.patientId == patientId ||
        isDoctorUser() ||
        isDoctorRole()
      );
      allow update: if isPatient(patientId) || isDoctorUser() || isDoctorRole();
      allow list: if isPatient(patientId);
      allow delete: if isPatient(patientId) || isDoctorUser() || isDoctorRole();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // APPOINTMENTS (nested slots under doctor)
    // ══════════════════════════════════════════════════════════════════════════
    match /appointments/{doctorId}/slots/{slotId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.doctorId == doctorId &&
        request.resource.data.patientId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctor(doctorId) ||
        isDoctorUser()
      );
      allow delete: if isSignedIn() && (
        resource.data.patientId == request.auth.uid ||
        isDoctor(doctorId) ||
        isDoctorUser()
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // COLLECTION GROUP: Allow patients to query their appointments across all doctors
    // ══════════════════════════════════════════════════════════════════════════
    match /{path=**}/slots/{slotId} {
      allow read: if isSignedIn() && resource.data.patientId == request.auth.uid;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // QUEUES (nested entries under clinic)
    // ══════════════════════════════════════════════════════════════════════════
    match /queues/{clinicId}/entries/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.patientId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.patientId ||
        isStaff() ||
        isDoctorUser()
      );
      allow list: if isSignedIn();
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.patientId ||
        isStaff() ||
        isDoctorUser()
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // PUSH NOTIFICATIONS (system-level, for Cloud Functions)
    // ══════════════════════════════════════════════════════════════════════════
    match /push_notifications/{notifId} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // NOTIFICATIONS (top-level app inbox entries)
    // ══════════════════════════════════════════════════════════════════════════
    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isDoctorUser()
      );
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff() ||
        isDoctorUser()
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff() ||
        isDoctorUser()
      );
    }

    // ══════════════════════════════════════════════════════════════════════════
    // LEGACY ALERTS (backward compatibility)
    // ══════════════════════════════════════════════════════════════════════════
    match /alerts/{alertId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CHAT CONVERSATIONS (for AI chat feature)
    // ══════════════════════════════════════════════════════════════════════════
    match /conversations/{conversationId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isDoctorRole() ||
        isDoctorUser()
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CHAT MESSAGES (nested under conversations)
    // ══════════════════════════════════════════════════════════════════════════
    match /conversations/{conversationId}/messages/{messageId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DENY ALL OTHER ACCESS (Security first!)
    // ══════════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}